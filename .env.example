# 数据库路径（默认：data/sequoia_v2.db）
DB_PATH=data/sequoia_v2.db

# 数据起始日期（默认：2024-01-01）
START_DATE=2024-01-01

# 默认飞书 Webhook URL（必填，作为 fallback）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/cb85d2a0-126a-4d06-92b6-8a6c815553b5

# 策略专属 Webhook（可选，格式：STRATEGY_WEBHOOK_<策略标识>=<URL>）
# 未配置的策略将自动使用默认 FEISHU_WEBHOOK_URL
STRATEGY_WEBHOOK_MA_VOLUME=https://open.feishu.cn/open-apis/bot/v2/hook/your-ma-volume-token
STRATEGY_WEBHOOK_BREAKOUT=https://open.feishu.cn/open-apis/bot/v2/hook/your-breakout-token
